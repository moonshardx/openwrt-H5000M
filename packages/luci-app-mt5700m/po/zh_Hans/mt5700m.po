msgid "MT5700M Management"
msgstr "MT5700M 管理"

msgid "Native LuCI management page for the MT5700M module network AT interface."
msgstr "用于 MT5700M 模块网络 AT 接口的 LuCI 原生管理页面。"

msgid "Connection"
msgstr "连接"

msgid "Connected"
msgstr "已连接"

msgid "Disconnected"
msgstr "未连接"

msgid "Module"
msgstr "模块"

msgid "SIM Status"
msgstr "SIM 状态"

msgid "Operator"
msgstr "运营商"

msgid "Network Mode"
msgstr "网络制式"

msgid "Module Temperature"
msgstr "模块温度"

msgid "NR Lock"
msgstr "NR 锁定"

