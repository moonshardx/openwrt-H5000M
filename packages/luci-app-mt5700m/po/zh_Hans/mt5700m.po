msgstr "网络与小区信息"

msgid "View serving cell, signal, frequency and registration information from the MT5700M module."
msgstr "查看 MT5700M 模块的服务小区、信号、频率和注册信息。"

msgid "Scanning, please wait..."
msgstr "正在扫描，请稍候..."

msgid "Cell scan may take some time and can briefly increase modem load."
msgstr "小区扫描可能需要一些时间，并会短暂增加模块负载。"

msgid "Cell Scan"
msgstr "小区扫描"

msgid "Frequency Lock"
msgstr "锁频控制"

msgid "Configure LTE and NR band, ARFCN or cell locks using native LuCI controls. Keep values empty to unlock."
msgstr "使用 LuCI 原生控件配置 LTE 和 NR 的频段、频点或小区锁定。留空会生成解锁命令。"

msgid "Unlock"
msgstr "解锁"

msgid "Band Lock"
msgstr "频段锁定"

msgid "ARFCN Lock"
msgstr "频点锁定"

msgid "Cell Lock"
msgstr "小区锁定"

msgid "Lock Type"
msgstr "锁定类型"

msgid "Bands"
msgstr "频段"

msgid "ARFCNs"
msgstr "频点"

msgid "SCS Types"
msgstr "SCS 类型"

msgid "PCI"
msgstr "PCI"

msgid "Command Preview"
msgstr "命令预览"

msgid "This command changes modem frequency lock state and may interrupt current connectivity."
msgstr "此命令会改变模块锁频状态，可能中断当前连接。"

msgid "Apply"
msgstr "应用"

msgid "SMS Center"
msgstr "短信中心"

msgid "Read, send and delete SMS messages through the MT5700M AT interface."
msgstr "通过 MT5700M AT 接口读取、发送和删除短信。"

