msgstr "刷新"

msgid "Unlock LTE/NR"
msgstr "解锁 LTE/NR"

msgid "Restart Module"
msgstr "重启模块"

msgid "This will unlock LTE and NR frequency locks. QModem may redial after the modem changes state."
msgstr "这会解除 LTE 和 NR 频率锁定。模块状态变化后，QModem 可能会重新拨号。"

msgid "This will restart the MT5700M module and temporarily interrupt 5G connectivity."
msgstr "这会重启 MT5700M 模块，并临时中断 5G 连接。"

msgid "Confirm Action"
msgstr "确认操作"

msgid "Continue"
msgstr "继续"

msgid "Cancel"
msgstr "取消"

msgid "Command completed."
msgstr "命令已完成。"

msgid "MT5700M AT Terminal"
msgstr "MT5700M AT 终端"

msgid "Send AT commands directly to the configured MT5700M network AT interface."
msgstr "直接向已配置的 MT5700M 网络 AT 接口发送 AT 命令。"

msgid "Enter AT command, for example AT^HCSQ?"
msgstr "输入 AT 命令，例如 AT^HCSQ?"

msgid "Send"
msgstr "发送"

msgid "Clear"
msgstr "清空"

msgid "Ready."
msgstr "就绪。"

