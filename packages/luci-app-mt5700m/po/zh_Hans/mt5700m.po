msgstr "删除选中的短信？"

msgid "Delete SMS"
msgstr "删除短信"

msgid "System and FOTA"
msgstr "系统与 FOTA"

msgid "View module system information and perform guarded FOTA operations. Firmware upgrade actions are high risk and require confirmation."
msgstr "查看模块系统信息，并执行带确认保护的 FOTA 操作。固件升级属于高风险操作，需要确认。"

msgid "Running..."
msgstr "正在执行..."

msgid "FOTA State"
msgstr "FOTA 状态"

msgid "FOTA Progress"
msgstr "FOTA 进度"

msgid "FOTA Upgrade"
msgstr "FOTA 升级"

msgid "FOTA Server URL"
msgstr "FOTA 服务器地址"

msgid "Initialize FOTA mode?"
msgstr "初始化 FOTA 模式？"

msgid "Initialize FOTA"
msgstr "初始化 FOTA"

msgid "Start FOTA download from the configured server URL?"
msgstr "从配置的服务器地址开始 FOTA 下载？"

msgid "Start Download"
msgstr "开始下载"

msgid "Resume suspended FOTA download?"
msgstr "继续已挂起的 FOTA 下载？"

msgid "Resume Download"
msgstr "继续下载"

msgid "Start firmware upgrade now? Do not power off the device during upgrade."
msgstr "现在开始固件升级？升级过程中请勿断电。"

msgid "Start Upgrade"
msgstr "开始升级"
