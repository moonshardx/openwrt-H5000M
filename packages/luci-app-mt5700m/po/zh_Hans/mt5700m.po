msgstr "命令为空。"

msgid "No response."
msgstr "无响应。"

msgid "Signal"
msgstr "信号"

msgid "Temperature"
msgstr "温度"

msgid "Cell Info"
msgstr "小区信息"

msgid "Configure the MT5700M module network AT endpoint used by the native LuCI pages."
msgstr "配置 LuCI 原生页面使用的 MT5700M 模块网络 AT 接口。"

msgid "Enable"
msgstr "启用"

msgid "AT Host"
msgstr "AT 主机"

msgid "AT Port"
msgstr "AT 端口"

