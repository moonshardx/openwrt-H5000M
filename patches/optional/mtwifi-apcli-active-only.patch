+function cfg_is_true(val)
+    return val == true or val == 1 or val == "1" or val == "true" or val == "yes" or val == "on"
+end
+
+function vif_is_enabled(v)
+    return v and v.config and not cfg_is_true(v.config.disabled)
+end
+
+function sorted_vif_indices(cfg)
+    local indices = {}
+
+    if not cfg or not cfg.interfaces then
+        return indices
+    end
+
+    for k,_ in pairs(cfg.interfaces) do
+        local idx = tonumber(k)
+        if idx ~= nil then
+            indices[#indices + 1] = idx
+        end
+    end
+
+    table.sort(indices)
+    return indices
+end
+
+function mac_add_offset(mac, offset)
+    if type(mac) ~= "string" then
+        return ""
+    end
+
+    local bytes = {}
+    for octet in string.gmatch(string.lower(mac), "[%da-f][%da-f]") do
+        bytes[#bytes + 1] = tonumber(octet, 16)
+    end
+
+    if #bytes ~= 6 then
+        return ""
+    end
+
+    local carry = tonumber(offset) or 0
+    for i = 6, 1, -1 do
+        local sum = bytes[i] + (carry % 256)
+        bytes[i] = sum % 256
+        carry = math.floor(carry / 256) + math.floor(sum / 256)
+    end
+
+    -- Keep a unicast, locally administered address for APCLI.
+    local first = bytes[1]
+    if (first % 2) == 1 then
+        first = first - 1
+    end
+    if (math.floor(first / 2) % 2) == 0 then
+        first = first + 2
+    end
+    bytes[1] = first
+
+    return string.format(
+        "%02x:%02x:%02x:%02x:%02x:%02x",
+        bytes[1], bytes[2], bytes[3], bytes[4], bytes[5], bytes[6]
+    )
+end
+
+function resolve_apcli_macaddr(v, dats)
+    local explicit = (v and v.config and v.config.macaddr) or ""
+    if explicit ~= "" then
+        return string.lower(explicit)
+    end
+
+    local base = dats.MacAddress or dats.MacAddress_Default or ""
+    local derived = mac_add_offset(base, 2)
+    if derived ~= "" then
+        return derived
+    end
+
+    return base
+end
